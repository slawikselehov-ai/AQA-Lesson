import java.util.Arrays;

public class Main {
    public static void main(String[] args) {

        String filePath = "data.csv";

        // создаем данные
        String[] header = {"Value1", "Value2", "Value3"};
        int[][] data = {
                {1, 2, 3},
                {4, 5, 6},
                {7, 8, 9}
        };

        AppData appData = new AppData(header, data);

        // сохраняем
        CsvHandler.save(appData, filePath);
        System.out.println("Данные сохранены.");

        // загружаем
        AppData loadedData = CsvHandler.load(filePath);

        // выводим
        System.out.println("\nЗаголовок:");
        System.out.println(Arrays.toString(loadedData.getHeader()));

        System.out.println("\nДанные:");
        for (int[] row : loadedData.getData()) {
            System.out.println(Arrays.toString(row));
        }
    }
}
