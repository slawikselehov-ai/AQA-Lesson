import java.util.*;

public class Task3 {
    public static void main(String[] args) {

        List<String> list = Arrays.asList("f10", "f15", "f2", "f4", "f4");

        // сортировка по числу после "f"
        list.sort(Comparator.comparingInt(s -> Integer.parseInt(s.substring(1))));

        // перенос в массив
        String[] resultArray = list.toArray(new String[0]);

        System.out.println("Отсортированный массив:");
        for (String s : resultArray) {
            System.out.print(s + " ");
        }
    }
}
